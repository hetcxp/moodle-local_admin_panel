<div class="ap-metrics-grid">
    <div class="ap-card">
        <div class="ap-card-title">{{#str}}metrics_courses_title, local_admin_panel{{/str}}</div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}courses_total, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{courses_total}}</span>
        </div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}courses_active, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{courses_active}}</span>
        </div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}courses_inactive, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{courses_inactive}}</span>
        </div>
    </div>
    <div class="ap-card">
        <div class="ap-card-title">{{#str}}metrics_users_title, local_admin_panel{{/str}}</div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}users_total, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{users_total}}</span>
        </div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}users_active, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{users_active}}</span>
        </div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}users_inactive, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{users_inactive}}</span>
        </div>
    </div>
    <div class="ap-card">
        <div class="ap-card-title">{{#str}}metrics_cohorts_title, local_admin_panel{{/str}}</div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}cohorts_total, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{cohorts_total}}</span>
        </div>
        <div class="ap-metric">
            <span class="ap-metric-label">{{#str}}cohorts_users_total, local_admin_panel{{/str}}</span>
            <span class="ap-metric-value">{{cohorts_users_total}}</span>
        </div>
    </div>
</div>
